    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "lectures": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lecture.lecture",
      "mappedBy": "class"
    },
    "department": {
      "type": "string"
    },
    "semester": {
      "type": "integer"
    },
    "batch_year": {
      "type": "integer"
    }
  }
}
